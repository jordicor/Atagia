ATAGIA_SQLITE_PATH=./data/atagia.db
ATAGIA_MIGRATIONS_PATH=./migrations
ATAGIA_MANIFESTS_PATH=./manifests
ATAGIA_STORAGE_BACKEND=inprocess
ATAGIA_REDIS_URL=redis://localhost:6379/0
ATAGIA_LLM_PROVIDER=anthropic
ATAGIA_LLM_API_KEY=
ATAGIA_OPENAI_API_KEY=
ATAGIA_OPENROUTER_API_KEY=
ATAGIA_LLM_BASE_URL=
ATAGIA_OPENROUTER_SITE_URL=http://localhost
ATAGIA_OPENROUTER_APP_NAME=Atagia
# Model suggestions: claude-sonnet-4-6, gpt-4o, or any model your provider supports
ATAGIA_LLM_EXTRACTION_MODEL=claude-sonnet-4-6
ATAGIA_LLM_SCORING_MODEL=claude-haiku-4-5-20251001
ATAGIA_LLM_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
ATAGIA_LLM_CHAT_MODEL=claude-sonnet-4-6
# Embeddings are optional. Leave backend=none to run FTS-only retrieval.
ATAGIA_EMBEDDING_BACKEND=none
# Optional manual override for which provider handles embeddings.
# Example dual-provider setup:
# ATAGIA_LLM_PROVIDER=anthropic
# ATAGIA_LLM_API_KEY=your-anthropic-key
# ATAGIA_OPENAI_API_KEY=your-openai-key
# ATAGIA_EMBEDDING_BACKEND=sqlite_vec
# ATAGIA_EMBEDDING_PROVIDER=openai
# ATAGIA_EMBEDDING_MODEL=text-embedding-3-small
# Or use OpenRouter by setting ATAGIA_EMBEDDING_PROVIDER=openrouter and ATAGIA_OPENROUTER_API_KEY.
ATAGIA_EMBEDDING_PROVIDER=
# Example: text-embedding-3-small. Required when backend=sqlite_vec.
ATAGIA_EMBEDDING_MODEL=
# Must match the configured embedding model output dimension.
ATAGIA_EMBEDDING_DIMENSION=1536
# FastAPI service mode is the safe default for HTTP deployments.
ATAGIA_SERVICE_MODE=true
ATAGIA_SERVICE_API_KEY=
ATAGIA_ADMIN_API_KEY=
# Local-only escape hatch for development. Keep false outside localhost.
ATAGIA_ALLOW_INSECURE_HTTP=false
ATAGIA_WORKERS_ENABLED=true
ATAGIA_DEBUG=false
ATAGIA_LIFECYCLE_DECAY_DAYS=7
ATAGIA_LIFECYCLE_DECAY_RATE=0.9
ATAGIA_LIFECYCLE_ARCHIVE_VITALITY=0.05
ATAGIA_LIFECYCLE_ARCHIVE_CONFIDENCE=0.3
ATAGIA_LIFECYCLE_EPHEMERAL_TTL_HOURS=24
ATAGIA_LIFECYCLE_REVIEW_TTL_DAYS=7
ATAGIA_PROMOTION_CONV_TO_WS_MIN_CONVERSATIONS=2
ATAGIA_PROMOTION_WS_TO_GLOBAL_MIN_SESSIONS=3
ATAGIA_PROMOTION_REQUIRE_MODE_CONSISTENCY=true
