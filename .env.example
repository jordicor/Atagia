ATAGIA_SQLITE_PATH=./data/atagia.db
ATAGIA_MIGRATIONS_PATH=./migrations
ATAGIA_MANIFESTS_PATH=./manifests
ATAGIA_STORAGE_BACKEND=inprocess
ATAGIA_REDIS_URL=redis://localhost:6379/0
ATAGIA_ANTHROPIC_API_KEY=
ATAGIA_OPENAI_API_KEY=
ATAGIA_KIMI_API_KEY=
ATAGIA_MINIMAX_API_KEY=
ATAGIA_GOOGLE_API_KEY=
ATAGIA_OPENROUTER_API_KEY=
ATAGIA_ANTHROPIC_BASE_URL=
ATAGIA_OPENAI_BASE_URL=
ATAGIA_KIMI_BASE_URL=
ATAGIA_MINIMAX_BASE_URL=
ATAGIA_OPENROUTER_BASE_URL=
ATAGIA_OPENROUTER_SITE_URL=http://localhost
ATAGIA_OPENROUTER_APP_NAME=Atagia
# Model values are provider-qualified: provider/model[,thinking_level].
# Default component models use direct MiniMax M3 for ingest/compaction,
# OpenRouter Gemini Flash-Lite for retrieval, OpenRouter DeepSeek v4 Flash for
# chat, and Anthropic for privacy/consent/export-sensitive helpers. To run
# everything on one provider for smoke tests, set ATAGIA_LLM_FORCED_GLOBAL_MODEL.
# Benchmark CLIs default to direct Kimi K2.7 Code for judging stability.
# Use stable Gemini Flash-Lite for retrieval; do not use the deprecated
# -preview slug.
ATAGIA_LLM_FORCED_GLOBAL_MODEL=
ATAGIA_LLM_INGEST_MODEL=
ATAGIA_LLM_RETRIEVAL_MODEL=
ATAGIA_LLM_CHAT_MODEL=
# Component override examples:
# ATAGIA_LLM_MODEL__EXTRACTOR=minimax/MiniMax-M3
# ATAGIA_LLM_MODEL__COMPACTOR=minimax/MiniMax-M3
# ATAGIA_LLM_RETRIEVAL_MODEL=openrouter/google/gemini-3.1-flash-lite
# ATAGIA_LLM_MODEL__NEED_DETECTOR_SEARCH_WORDS=openrouter/google/gemini-3.1-flash-lite
# ATAGIA_LLM_MODEL__CHAT=openrouter/deepseek/deepseek-v4-flash
# Optional intimacy fallback models. These are only used when an LLM-backed
# ingest/retrieval component receives a provider policy block or refusal.
ATAGIA_LLM_INTIMACY_INGEST_MODEL=
ATAGIA_LLM_INTIMACY_RETRIEVAL_MODEL=
# When true, known intimate contexts use configured intimacy models directly
# instead of probing the primary model first.
ATAGIA_LLM_INTIMACY_PROACTIVE_ROUTING_ENABLED=false
# Component-level intimacy fallback examples:
# ATAGIA_LLM_INTIMACY_MODEL__EXTRACTOR=openrouter/z-ai/glm-4.6
# ATAGIA_LLM_INTIMACY_MODEL__COMPACTOR=openrouter/z-ai/glm-4.6
# ATAGIA_LLM_INTIMACY_MODEL__APPLICABILITY_SCORER=openrouter/x-ai/grok-4.1-fast
# Embeddings are optional. Leave backend=none to run FTS-only retrieval.
ATAGIA_EMBEDDING_BACKEND=none
# Example mixed-provider setup:
# ATAGIA_ANTHROPIC_API_KEY=your-anthropic-key
# ATAGIA_OPENROUTER_API_KEY=your-openrouter-key
# ATAGIA_OPENAI_API_KEY=your-openai-key
# ATAGIA_KIMI_API_KEY=your-kimi-key
# ATAGIA_MINIMAX_API_KEY=your-minimax-key
# ATAGIA_EMBEDDING_BACKEND=sqlite_vec
# ATAGIA_EMBEDDING_MODEL=openai/text-embedding-3-small
ATAGIA_EMBEDDING_MODEL=openai/text-embedding-3-small
# Must match the configured embedding model output dimension.
ATAGIA_EMBEDDING_DIMENSION=1536
# Candidate-generation tuning for sqlite-vec. Applicability scoring remains
# the final authority.
ATAGIA_EMBEDDING_VECTOR_LIMIT_CAP=50
ATAGIA_EMBEDDING_SEARCH_OVERFETCH_MULTIPLIER=4
# FTS5 BM25 column weights for memory_objects_fts(canonical_text, index_text).
ATAGIA_MEMORY_FTS_CANONICAL_BM25_WEIGHT=1.2
ATAGIA_MEMORY_FTS_INDEX_BM25_WEIGHT=0.8
# FastAPI service mode is the safe default for HTTP deployments.
ATAGIA_SERVICE_MODE=true
ATAGIA_SERVICE_API_KEY=
ATAGIA_ADMIN_API_KEY=
# OpenAI-compatible memory proxy. Clients can set their visible model to
# ATAGIA_PROXY_MODEL_ID while Atagia forwards to ATAGIA_PROXY_UPSTREAM_MODEL,
# or to the configured chat model when unset.
ATAGIA_PROXY_MODEL_ID=atagia-memory-proxy
ATAGIA_PROXY_UPSTREAM_MODEL=
ATAGIA_PROXY_DEFAULT_MODE=
# Required only for browser-based native extensions that call Atagia directly.
# Example: http://127.0.0.1:8000,http://localhost:8000
ATAGIA_CORS_ALLOWED_ORIGINS=
# Local-only escape hatch for development. Keep false outside localhost.
ATAGIA_ALLOW_INSECURE_HTTP=false
ATAGIA_WORKERS_ENABLED=true
ATAGIA_DEBUG=false
# Opt-in local/benchmark LLM IO diagnostics. Keep disabled outside development.
ATAGIA_DEBUG_LLM_IO=false
ATAGIA_DEBUG_LLM_IO_DIR=./docs/tmp/llm_debug
ATAGIA_DEBUG_LLM_IO_PURPOSES=
ATAGIA_DEBUG_LLM_IO_RAW=false
ATAGIA_DEBUG_LLM_IO_MAX_CHARS=50000
ATAGIA_LIFECYCLE_DECAY_DAYS=7
ATAGIA_LIFECYCLE_DECAY_RATE=0.9
ATAGIA_LIFECYCLE_ARCHIVE_VITALITY=0.05
ATAGIA_LIFECYCLE_ARCHIVE_CONFIDENCE=0.3
ATAGIA_LIFECYCLE_EPHEMERAL_TTL_HOURS=24
ATAGIA_LIFECYCLE_REVIEW_TTL_DAYS=7
ATAGIA_PROMOTION_CONV_TO_WS_MIN_CONVERSATIONS=2
ATAGIA_PROMOTION_WS_TO_GLOBAL_MIN_SESSIONS=3
ATAGIA_PROMOTION_REQUIRE_MODE_CONSISTENCY=true
