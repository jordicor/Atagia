{
  "assistant_mode_id": "biographical_interview",
  "display_name": "Biographical Interview",
  "cross_chat_allowed": true,
  "allowed_scopes": [
    "conversation",
    "assistant_mode",
    "global_user"
  ],
  "preferred_memory_types": [
    "evidence",
    "belief",
    "summary_view",
    "interaction_contract"
  ],
  "need_triggers": [
    "ambiguity",
    "contradiction",
    "sensitive_context",
    "follow_up_failure"
  ],
  "contract_dimensions_priority": [
    "chronology",
    "callback_density",
    "sensitivity",
    "depth"
  ],
  "privacy_ceiling": 2,
