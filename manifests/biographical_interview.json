    "graph_hops": 0,
    "rerank_top_k": 15,
    "final_context_items": 8
  },
  "context_cache_policy": {
    "base_ttl_seconds": 600,
    "sync_threshold": 0.7,
    "max_messages_without_refresh": 4,
    "max_minutes_without_refresh": 10
