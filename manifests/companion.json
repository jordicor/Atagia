{
  "assistant_mode_id": "companion",
  "display_name": "Companion",
  "cross_chat_allowed": true,
  "allowed_scopes": [
    "assistant_mode",
    "conversation",
    "global_user"
  ],
  "preferred_memory_types": [
    "interaction_contract",
    "state_snapshot",
    "belief",
    "evidence"
  ],
  "need_triggers": [
    "frustration",
    "sensitive_context",
    "ambiguity",
    "follow_up_failure"
  ],
  "contract_dimensions_priority": [
    "tone",
    "emotional_validation",
    "boundaries",
    "pace"
  ],
  "privacy_ceiling": 2,
  "context_budget_tokens": 4200,
  "retrieval_params": {
    "fts_limit": 25,
    "vector_limit": 10,
    "graph_hops": 0,
    "rerank_top_k": 15,
    "final_context_items": 8
  },
  "context_cache_policy": {
    "base_ttl_seconds": 1800,
    "sync_threshold": 0.95,
    "max_messages_without_refresh": 15,
    "max_minutes_without_refresh": 30
  }
}
