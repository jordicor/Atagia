{
  "assistant_mode_id": "general_qa",
  "display_name": "General QA",
  "cross_chat_allowed": false,
  "allowed_scopes": [
    "conversation",
    "ephemeral_session"
  ],
  "preferred_memory_types": [
    "interaction_contract",
    "evidence",
    "state_snapshot"
  ],
  "need_triggers": [
    "ambiguity",
    "follow_up_failure",
    "under_specified_request"
  ],
  "contract_dimensions_priority": [
    "directness",
    "brevity",
    "clarification_tolerance",
    "pace"
  ],
  "privacy_ceiling": 2,
  "context_budget_tokens": 2800,
  "transcript_budget_tokens": 4000,
  "retrieval_params": {
    "fts_limit": 25,
    "vector_limit": 10,
    "graph_hops": 0,
    "rerank_top_k": 15,
    "final_context_items": 8
  },
  "context_cache_policy": {
    "base_ttl_seconds": 900,
    "sync_threshold": 0.9,
    "max_messages_without_refresh": 8,
    "max_minutes_without_refresh": 20
  }
}
